---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="mx-auto flex min-h-dvh max-w-3xl flex-col gap-10 px-5 py-12 sm:py-16"
  >
    <header class="flex flex-col gap-3">
      <h1
        class="font-display text-5xl font-bold tracking-tight text-text sm:text-6xl"
      >
        quilt<span class="text-stitch">.</span>
      </h1>
      <p class="text-lg text-muted">
        every GitHub account you have, stitched into one quilt of green.
      </p>
    </header>

    <form id="quilt-form" class="flex flex-col gap-3 sm:flex-row">
      <input
        id="quilt-input"
        name="u"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        placeholder="jassuwu, torvalds"
        aria-label="GitHub usernames, comma or space separated"
        class="flex-1 rounded-lg border border-seam bg-surface px-4 py-3 font-mono text-text outline-none placeholder:text-muted/50 focus:border-accent"
      />
      <button
        type="submit"
        class="rounded-lg bg-accent px-5 py-3 font-medium text-bg transition hover:brightness-110"
      >
        stitch →
      </button>
    </form>

    <p
      id="quilt-status"
      class="hidden text-sm text-muted"
      role="status"
      aria-live="polite"
    >
    </p>

    <section id="quilt-result" class="hidden flex-col gap-8">
      <dl id="quilt-stats" class="flex flex-wrap gap-x-10 gap-y-4"></dl>

      <div id="quilt-years" class="hidden flex-wrap gap-2"></div>

      <div>
        <div id="quilt-graph"></div>
        <div
          class="mt-3 flex items-center justify-end gap-2 text-xs text-muted"
        >
          <span>less</span>
          <span class="inline-flex items-center gap-[3px]">
            <!-- swatches mirror src/lib/levels.ts LEVEL_HEX -->
            <span
              class="inline-block size-[11px] rounded-[2px]"
              style="background:#161b22"></span>
            <span
              class="inline-block size-[11px] rounded-[2px]"
              style="background:#0e4429"></span>
            <span
              class="inline-block size-[11px] rounded-[2px]"
              style="background:#006d32"></span>
            <span
              class="inline-block size-[11px] rounded-[2px]"
              style="background:#26a641"></span>
            <span
              class="inline-block size-[11px] rounded-[2px]"
              style="background:#39d353"></span>
          </span>
          <span>more</span>
        </div>
      </div>

      <div class="flex flex-col gap-4 border-t border-seam pt-6">
        <p class="text-sm text-muted">
          embed your live quilt — drop it in your README or portfolio, it keeps
          itself current. style it to match your site:
        </p>

        <div id="quilt-embed-preview" class="overflow-x-auto"></div>

        <div
          class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-muted"
        >
          <label class="flex items-center gap-2">
            graph
            <input
              id="quilt-embed-color"
              type="color"
              value="#39d353"
              aria-label="graph color"
              class="size-7 cursor-pointer rounded border border-seam bg-transparent"
            />
          </label>
          <label class="flex items-center gap-2">
            background
            <input
              id="quilt-embed-bg"
              type="color"
              value="#0d1117"
              aria-label="background color"
              class="size-7 cursor-pointer rounded border border-seam bg-transparent"
            />
          </label>
          <span class="text-xs">(and pick a year above)</span>
          <button
            id="quilt-embed-reset"
            type="button"
            class="text-stitch underline-offset-2 hover:underline">reset</button
          >
        </div>

        <div class="flex flex-col gap-2">
          <div id="quilt-embed-tabs" class="flex gap-1 text-xs"></div>
          <div class="flex items-stretch gap-2">
            <code
              id="quilt-embed-code"
              class="flex-1 overflow-x-auto whitespace-nowrap rounded-lg border border-seam bg-surface px-3 py-2.5 font-mono text-sm text-text"
            ></code>
            <button
              id="quilt-embed-copy"
              type="button"
              class="shrink-0 rounded-lg bg-accent px-4 font-medium text-bg transition hover:brightness-110"
            >
              copy
            </button>
          </div>
        </div>
      </div>
    </section>

    <footer class="mt-auto flex flex-col gap-3 pt-10 text-sm">
      <p class="text-muted">
        <span class="font-medium text-stitch">tip</span>: turn on <span
          class="text-text"
          >Settings → Public profile → “Include private contributions on my
          profile”</span
        > so your private-repo work counts here too. only the green squares show up,
        never the details.
      </p>
      <p class="text-muted">
        data from <a
          class="text-stitch underline-offset-2 hover:underline"
          href="https://github.com/grubersjoe/github-contributions-api"
          rel="noopener">github-contributions-api</a
        > · built by <a
          class="text-stitch underline-offset-2 hover:underline"
          href="https://jass.gg"
          rel="noopener">jass</a
        > · not affiliated with GitHub
      </p>
    </footer>
  </main>

  <script>
    import "../scripts/quilt.ts";
  </script>
</Layout>
