---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <main
    class="mx-auto flex min-h-dvh max-w-3xl flex-col gap-10 px-5 py-12 sm:py-16"
  >
    <header class="flex flex-col gap-3">
      <h1
        class="font-display text-5xl font-bold tracking-tight text-text sm:text-6xl"
      >
        quilt<span class="text-stitch">.</span>
      </h1>
      <p class="text-lg text-muted">
        every GitHub account you have, stitched into one quilt of green.
      </p>
    </header>

    <div class="flex flex-col gap-3">
      <form id="quilt-form" class="flex flex-col gap-3 sm:flex-row">
        <input
          id="quilt-input"
          name="u"
          type="text"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          enterkeyhint="go"
          placeholder="jassuwu, torvalds"
          aria-label="GitHub usernames, comma or space separated"
          class="flex-1 rounded-lg border border-seam bg-surface px-4 py-3 font-mono text-text outline-none placeholder:text-muted/50 focus:border-accent"
        />
        <button
          type="submit"
          class="rounded-lg bg-accent px-5 py-3 font-medium text-bg transition hover:brightness-110"
        >
          stitch →
        </button>
      </form>
      <!-- one subline slot: the example link before a stitch, notes/errors after -->
      <p id="quilt-example-row" class="text-sm text-muted">
        or <a
          id="quilt-example"
          href="/?u=jassuwu,torvalds"
          class="text-stitch underline-offset-2 hover:underline"
          >see an example quilt →</a
        >
      </p>
      <p
        id="quilt-status"
        class="hidden text-sm text-muted"
        role="status"
        aria-live="polite"
      >
      </p>
    </div>

    <section id="quilt-result" class="hidden flex-col gap-8">
      <!--
        the one artifact: the embed card itself is the page quilt. its footer
        carries the legend, accounts, total and attribution — so the page adds
        only a quiet caption above and the knobs below.
      -->
      <div class="flex flex-col gap-3">
        <!-- role=status: hearing the merged numbers IS the "done" signal -->
        <p id="quilt-stats" role="status" class="text-sm text-muted"></p>

        <div
          id="quilt-graph"
          tabindex="0"
          role="region"
          aria-label="merged contribution quilt, scrolls horizontally on small screens"
          class="overflow-x-auto transition-opacity duration-300"
        >
        </div>

        <div
          class="flex flex-wrap items-center gap-x-6 gap-y-3 text-sm text-muted"
        >
          <label class="flex items-center gap-2">
            year
            <select
              id="quilt-year"
              class="cursor-pointer rounded-lg border border-seam bg-surface px-2.5 py-1.5 text-sm text-text outline-none focus:border-accent"
            ></select>
          </label>
          <label class="flex items-center gap-2">
            theme
            <select
              id="quilt-theme"
              class="cursor-pointer rounded-lg border border-seam bg-surface px-2.5 py-1.5 text-sm text-text outline-none focus:border-accent"
            ></select>
          </label>
          <span id="quilt-custom" class="hidden items-center gap-x-6 gap-y-3">
            <label class="flex items-center gap-2">
              graph
              <input
                id="quilt-color"
                type="color"
                value="#39d353"
                aria-label="graph color"
                class="size-7 cursor-pointer rounded border border-seam bg-transparent"
              />
            </label>
            <label class="flex items-center gap-2">
              background
              <input
                id="quilt-bg"
                type="color"
                value="#0d1117"
                aria-label="background color"
                class="size-7 cursor-pointer rounded border border-seam bg-transparent"
              />
            </label>
          </span>
        </div>
      </div>

      <div class="flex flex-col gap-3">
        <p class="text-sm text-muted">
          what you see is what you paste. this card goes live in your README,
          anywhere an <code class="font-mono text-xs text-text"
            >&lt;img&gt;</code
          > works:
        </p>
        <div class="flex flex-wrap items-stretch gap-2">
          <select
            id="quilt-fmt"
            aria-label="embed format"
            class="cursor-pointer rounded-lg border border-seam bg-surface px-2.5 py-1.5 text-sm text-text outline-none focus:border-accent"
          >
            <option value="md">markdown</option>
            <option value="html">html</option>
            <option value="auto">auto light/dark</option>
            <option value="url">url</option>
          </select>
          <code
            id="quilt-embed-code"
            class="min-w-48 flex-1 overflow-x-auto whitespace-nowrap rounded-lg border border-seam bg-surface px-3 py-2.5 font-mono text-sm text-text"
          ></code>
          <button
            id="quilt-embed-copy"
            type="button"
            class="shrink-0 rounded-lg bg-accent px-4 py-2 font-medium text-bg transition hover:brightness-110"
          >
            copy
          </button>
        </div>
        <p class="text-xs text-muted">
          or: <button
            id="quilt-share"
            type="button"
            class="-mx-1 -my-2 px-1 py-2 text-stitch underline-offset-2 hover:underline"
            >copy link</button
          > · <button
            id="quilt-download"
            type="button"
            class="-mx-1 -my-2 px-1 py-2 text-stitch underline-offset-2 hover:underline"
            >download png</button
          >
        </p>
      </div>
    </section>

    <section
      class="flex flex-col gap-3 border-t border-dashed border-seam pt-6 text-sm text-muted"
    >
      <h2 class="font-display text-base font-semibold text-text">
        how it works
      </h2>
      <p>
        type your GitHub usernames and quilt fetches each account's contribution
        calendar, sums every day's count across accounts, recomputes the green
        levels from the merged distribution, and paints them into one quilt. a
        work account and a personal account stop looking like two half-dead
        profiles.
      </p>
      <p>
        no login. nothing stored. the fetch and merge happen in your browser,
        and the result lives in the URL, so it's a shareable link. the embed is
        one server-rendered SVG that works anywhere an
        <code class="font-mono text-xs text-text">&lt;img&gt;</code> does, GitHub
        and GitLab READMEs included.
      </p>
    </section>

    <footer
      class="mt-auto flex flex-col gap-3 border-t border-dashed border-seam pt-6 text-sm"
    >
      <p class="text-muted">
        <span class="font-medium text-stitch">tip</span>: turn on <span
          class="text-text"
          >Settings → Public profile → “Include private contributions on my
          profile”</span
        > so your private-repo work counts here too. only the green squares show up,
        never the details.
      </p>
      <p class="text-muted">
        <a
          class="text-stitch underline-offset-2 hover:underline"
          href="https://github.com/jassuwu/quilt"
          rel="noopener">source</a
        > · data from <a
          class="text-stitch underline-offset-2 hover:underline"
          href="https://github.com/grubersjoe/github-contributions-api"
          rel="noopener">github-contributions-api</a
        > · built by <a
          class="text-stitch underline-offset-2 hover:underline"
          href="https://jass.gg"
          rel="noopener">jass</a
        > · not affiliated with GitHub
      </p>
    </footer>
  </main>

  <script>
    import "../scripts/quilt.ts";
  </script>
</Layout>
