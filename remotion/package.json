{
  "name": "remotion",
  "version": "1.0.0",
  "description": "quilt — animated demos (hero + social) for the README and socials",
  "repository": {},
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "@remotion/cli": "4.0.474",
    "@remotion/google-fonts": "^4.0.474",
    "@remotion/tailwind-v4": "4.0.474",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remotion": "4.0.474",
    "tailwindcss": "4.0.0"
  },
  "devDependencies": {
    "@remotion/eslint-config-flat": "4.0.474",
    "@types/react": "19.2.7",
    "@types/web": "0.0.166",
    "eslint": "9.19.0",
    "prettier": "3.8.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "dev": "remotionb studio",
    "build": "remotionb bundle",
    "upgrade": "remotionb upgrade",
    "lint": "eslint src && tsc",
    "poster": "remotionb still src/index.ts hero out/quilt-poster.png --frame=170",
    "render:hero": "remotionb render src/index.ts hero out/quilt-hero.mp4",
    "render:social": "remotionb render src/index.ts social out/quilt-social.mp4"
  },
  "sideEffects": [
    "*.css"
  ]
}